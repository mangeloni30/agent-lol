# Riot Games API key (development keys expire every 24h)
# Get yours at: https://developer.riotgames.com/
API_KEY=RGAPI-your-api-key-here

# Summoner Riot ID used for get-puuid and UI display
GAME_NAME=YourGameName
TAG_LINE=1234

# Optional: OpenAI key for match context agent. Set ENABLE_MATCH_AGENT=true to use it.
# OPENAI_KEY=sk-your-key
# ENABLE_MATCH_AGENT=false

# Timeline compare: value in milliseconds, used as minute for AI comparison (e.g. 60000=1min, 180000=3min)
# TIMELINE_COMPARE=180000
